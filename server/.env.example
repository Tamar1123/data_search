# ── LLM ───────────────────────────────────────────────────────────────────────
# Required. Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Required in production. Any long random string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── Database ───────────────────────────────────────────────────────────────────
# Optional. Defaults to server/data/data.db next to server.py.
# Set to a mounted volume path on Railway (e.g. /data/data.db) for persistence.
# DB_PATH=/data/data.db

# ── CORS ───────────────────────────────────────────────────────────────────────
# Optional. Defaults to * (allow all origins).
# Set to your frontend URL in production to restrict access.
# ALLOWED_ORIGIN=https://your-frontend.railway.app

# ── Server ────────────────────────────────────────────────────────────────────
# Optional. Port used when running with `python server.py` directly.
# Gunicorn on Railway uses $PORT automatically via the Procfile.
# PORT=5000

# ── Environment ───────────────────────────────────────────────────────────────
# Optional. Set to production on Railway.
# FLASK_ENV=production
